# Non-secret local port and image overrides only.
POOLAI_API_PORT=8080
POOLAI_FRONTEND_PORT=5173
POOLAI_MOCK_UPSTREAM_PORT=4010
POOLAI_MAILPIT_UI_PORT=8025

# Set all three image variables together to consume prebuilt images instead of
# packaging artifacts/publish/PoolAI.{Api,Worker,Migrator}.
# POOLAI_API_IMAGE=registry.example/poolai-api@sha256:<digest>
# POOLAI_WORKER_IMAGE=registry.example/poolai-worker@sha256:<digest>
# POOLAI_MIGRATOR_IMAGE=registry.example/poolai-migrator@sha256:<digest>

# Compose itself requires this variable and has no fallback. The helper scripts
# set it to the ignored repository-local directory below without storing values
# in this file.
# POOLAI_SECRET_DIR=/absolute/path/to/PoolAI/.tools/compose/secrets
